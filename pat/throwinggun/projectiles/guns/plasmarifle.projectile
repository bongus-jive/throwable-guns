  "scripts": [ "throwngun.lua" ],
  "throwngunConfig": {
    "rotationRate": 18,
    "rotationDeviation": 5,

    "emptyTimeToLive": 0.5,
    "emptyBounces": 8,
    "hitBounceFactor": 0.8,
    "fireOnHit": true,

    "ammo": 18,
    "burstCount": 2,

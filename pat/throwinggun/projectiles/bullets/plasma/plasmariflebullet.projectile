{
  "projectileName": "pat_throwingplasmarifle_bullet",
  "physics": "laser",
  "image": "plasmariflebullet.png",
  "fullbright": true,
  "orientationLocked": true,
  "speed": 80,
  "knockback": 6,
  "timeToLive": 3,
  "lightColor": [ 0, 60, 120 ],
  "damageKind": "electricplasmabullet",
  "movementSettings": {
    "bounceFactor": 0,
    "maximumCorrection": 0
  },
  "actionOnReap": [
    { "action": "sound", "options": [ "/sfx/gun/impact_plasma.ogg" ] },
    {
      "action": "sound",
      "options": [
        "/sfx/projectiles/plasmabullet_ricochet1.ogg",
        "/sfx/projectiles/plasmabullet_ricochet2.ogg",
        "/sfx/projectiles/plasmabullet_ricochet3.ogg"
      ]
    },
    {
      "action": "loop",
      "count": 4,
      "body": [
        {
          "action": "particle",
          "specification": {
            "type": "ember",
            "layer": "middle",
            "color": [ 90, 180, 230 ],
            "light": [ 0, 60, 120 ],
            "fade": 5,
            "size": 1.5,
            "fullbright": true,
            "timeToLive": 0.2,
            "destructionTime": 0.2,
            "destructionAction": "shrink",
            "finalVelocity": [ 0, -50 ],
            "approach": [ 0, 30 ],
            "variance": {
              "size": 0.5,
              "timeToLive": 0.1,
              "position": [ 0.25, 0.25 ],
              "initialVelocity": [ 13, 13 ]
            }
          }
        }
      ]
    }
  ],
  "periodicActions": [
    {
      "time": 0.015,
      "repeat": true,
      "action": "particle",
      "rotate": true,
      "specification": {
        "type": "streak",
        "color": [ 90, 180, 230 ],
        "size": 1.5,
        "length": 20,
        "velocity": [ 5, 0 ],
        "destructionTime": 0.1,
        "destructionAction": "shrink",
        "layer": "back"
      }
    }
  ]
}
